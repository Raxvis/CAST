{
  "_comment_top": "Example Claude Code settings for a project using this template. Copy to .claude/settings.json (remove the .example suffix), delete the _comment_* fields, and edit to taste. See docs/CLAUDE_CODE_SETTINGS.md for a walkthrough and docs.claude.com/en/docs/claude-code/settings for the authoritative reference.",

  "_comment_permissions": "Auto-approve safe, read-only shell commands so Claude Code stops asking every time. Only list commands you are certain are non-destructive on this project.",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(cat:*)"
    ]
  },

  "_comment_env": "Project-local environment variables Claude Code sees for every tool call. Use for things like database paths, feature flags, or test configuration. Do NOT store secrets here — this file is checked into git.",
  "env": {}
}
